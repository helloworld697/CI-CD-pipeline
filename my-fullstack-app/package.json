{
  "name": "fullstack-final",
  "version": "1.0.0",
  "scripts": {
    "install:all": "npm install && npm install --prefix backend && npm install --prefix frontend",
    "build": "npm run build --prefix frontend && npx shx rm -rf backend/dist && npx shx cp -r frontend/dist backend/dist",
    "start": "node backend/index.js",
    "test": "jest",
    "lint": "eslint .",
    "test:e2e": "playwright test",
    "eslint": "eslint ."
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@eslint/js": "^9.10.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "babel-jest": "^30.3.0",
    "eslint": "^9.10.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0"
  },
  "dependencies": {
    "express": "^5.2.1"
  },
  "jest": {
    "testEnvironment": "jsdom",
    
    "testPathIgnorePatterns": [
      "e2e-tests",
      "tests",
      "e2e"
    ]
  }
}
